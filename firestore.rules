// Purifies - Firestore Security Rules
// Deploy: Firebase Console → Firestore Database → Rules → paste this file → Publish
// Or: firebase deploy --only firestore:rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Role from current user's document (requires users/{uid} to exist)
    function getAuthRole() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function getOrderData(orderId) {
      return get(/databases/$(database)/documents/orders/$(orderId)).data;
    }
    
    function isCustomerAuth() {
      return getAuthRole() == 'customer';
    }
    
    function isVendorAuth() {
      return getAuthRole() == 'vendor';
    }
    
    // Users collection - users can read/write their own data
    match /users/{userId} {
      // Allow read if:
      // - User owns the document (their own profile)
      // - Document has role 'delivery' (vendors can find nearby delivery persons)
      allow read: if isAuthenticated() && (
        isOwner(userId) || 
        resource.data.role == 'delivery'
      );
      
      // Users can create their own document during registration
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      
      // Users can update their own data (including availability status for delivery persons)
      allow update: if isAuthenticated() && isOwner(userId);
      
      // Users can delete their own data
      allow delete: if isAuthenticated() && isOwner(userId);
      
      // Allow listing/querying users collection for authenticated users
      // Individual documents are filtered by read rules above
      // This allows vendors to query for delivery persons by pincode
      allow list: if isAuthenticated();
    }
    
    // Vendors collection
    match /vendors/{vendorId} {
      // Allow any authenticated user to read vendors (needed for admin dashboard)
      allow read: if isAuthenticated();
      
      // Vendors can create their own vendor document
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      
      // Allow updates: 
      // - Vendor can update their own data (if vendorId matches their uid)
      // - Any authenticated user can update (for admin approval/rejection)
      // Note: vendorId is the document ID which should match the uid field
      allow update: if isAuthenticated();
      
      // Allow listing all vendors for admin dashboard
      allow list: if isAuthenticated();
    }
    
    // Orders collection
    match /orders/{orderId} {
      // Allow read if:
      // - Customer owns the order
      // - Vendor owns the order
      // - Delivery person is assigned to the order
      allow read: if isAuthenticated() && (
        resource.data.customerUid == request.auth.uid ||
        resource.data.vendorUid == request.auth.uid ||
        resource.data.deliveryPersonUid == request.auth.uid
      );
      
      // Allow create if:
      // - Customer owns the order (regular orders)
      // - Vendor owns the order (subscription delivery orders created by vendor)
      allow create: if isAuthenticated() && (
        request.resource.data.customerUid == request.auth.uid ||
        request.resource.data.vendorUid == request.auth.uid
      );
      
      // Allow update if:
      // - Vendor owns the order (to accept/reject/assign delivery person)
      // - Customer owns the order (to cancel)
      // - Delivery person is assigned (to update status: start delivery, mark delivered)
      allow update: if isAuthenticated() && (
        resource.data.vendorUid == request.auth.uid ||
        resource.data.customerUid == request.auth.uid ||
        (
          getAuthRole() == 'delivery' &&
          resource.data.deliveryPersonUid == request.auth.uid &&
          (
            (
              resource.data.status in ['accepted', 'preparing'] &&
              request.resource.data.status == 'out_for_delivery'
            ) ||
            (
              resource.data.status == 'out_for_delivery' &&
              request.resource.data.status == 'delivered'
            )
          )
        )
      );
      
      // Allow listing/querying orders for authenticated users
      // Individual documents are filtered by read rules above
      allow list: if isAuthenticated();
    }

    // Delivery tracking documents for live courier location
    match /deliveryTracking/{orderId} {
      allow read: if isAuthenticated() && (
        getOrderData(orderId).customerUid == request.auth.uid ||
        getOrderData(orderId).vendorUid == request.auth.uid ||
        getOrderData(orderId).deliveryPersonUid == request.auth.uid
      );

      allow create, update: if isAuthenticated() &&
        getAuthRole() == 'delivery' &&
        getOrderData(orderId).deliveryPersonUid == request.auth.uid &&
        request.resource.data.orderId == orderId &&
        request.resource.data.deliveryPersonId == request.auth.uid;

      allow delete: if isAuthenticated() &&
        getAuthRole() == 'delivery' &&
        getOrderData(orderId).deliveryPersonUid == request.auth.uid;

      allow list: if false;
    }
    
    // Payments collection
    match /payments/{paymentId} {
      // Allow read if customer or vendor owns the payment
      allow read: if isAuthenticated() && (
        resource.data.customerUid == request.auth.uid ||
        resource.data.vendorUid == request.auth.uid
      );
      
      // Only the customer can create a payment record
      allow create: if isAuthenticated() &&
        isCustomerAuth() &&
        request.resource.data.customerUid == request.auth.uid;
      
      // Customer escalates INITIATED -> PAYMENT_REQUESTED; vendor approves/rejects
      allow update: if isAuthenticated() && (
        (
          isCustomerAuth() &&
          resource.data.customerUid == request.auth.uid &&
          resource.data.status == 'INITIATED' &&
          request.resource.data.status == 'PAYMENT_REQUESTED'
        ) ||
        (
          isVendorAuth() &&
          resource.data.vendorUid == request.auth.uid &&
          resource.data.status == 'PAYMENT_REQUESTED' &&
          request.resource.data.status in ['PAID', 'FAILED']
        )
      );
      
      allow list: if isAuthenticated();
    }
    
    // Subscriptions collection
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() &&
        (resource.data.customerUid == request.auth.uid ||
         resource.data.vendorUid == request.auth.uid);

      allow create: if isAuthenticated() &&
        getAuthRole() == 'customer' &&
        request.resource.data.customerUid == request.auth.uid;

      allow update: if isAuthenticated() && (
        (
          getAuthRole() == 'customer' &&
          resource.data.customerUid == request.auth.uid
        ) ||
        (
          getAuthRole() == 'vendor' &&
          resource.data.vendorUid == request.auth.uid
        )
      );

      allow list: if isAuthenticated();
    }

    match /subscriptionPayments/{paymentId} {
      allow read: if isAuthenticated() &&
        ((resource.data.customerUid != null && resource.data.customerUid == request.auth.uid) ||
         (resource.data.vendorUid != null && resource.data.vendorUid == request.auth.uid));

      allow create: if isAuthenticated() &&
        getAuthRole() == 'customer' &&
        request.resource.data.customerUid == request.auth.uid;

      allow update: if isAuthenticated() && (
        (
          getAuthRole() == 'customer' &&
          resource.data.customerUid == request.auth.uid &&
          resource.data.status == 'INITIATED' &&
          request.resource.data.status == 'PAYMENT_REQUESTED'
        ) ||
        (
          getAuthRole() == 'vendor' &&
          resource.data.vendorUid == request.auth.uid &&
          resource.data.status in ['PAYMENT_REQUESTED', 'SUCCESS'] &&
          request.resource.data.status == 'PAID'
        )
      );

      allow list: if isAuthenticated();
    }
    
    // Test collection for connection checking
    match /_test/{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
w